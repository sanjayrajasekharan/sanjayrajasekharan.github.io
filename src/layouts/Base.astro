---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Sanjay Rajasekharan — research, code, and data." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__name">Sanjay Rajasekharan</a>
        <nav>
          <ul class="site-nav">
            <li><a href="/" class:list={[{ active: currentPath === "/" }]}>Home</a></li>
            <li><a href="/blog" class:list={[{ active: currentPath.startsWith("/blog") }]}>Blog</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        &copy; {new Date().getFullYear()} Sanjay Rajasekharan
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
