---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Sanjay Rajasekharan — research, code, and data." } = Astro.props;
const path = Astro.url.pathname;
const isHome = path === "/";

const crumbs: { label: string; href: string }[] = [];
if (!isHome) {
  crumbs.push({ label: "Home", href: "/" });
  const segments = path.replace(/\/$/, "").split("/").filter(Boolean);
  if (segments.length > 1 && segments[0] === "blog") {
    crumbs.push({ label: "Blog", href: "/blog/" });
  }
  if (segments.length > 1 && segments[0] === "projects") {
    crumbs.push({ label: "Projects", href: "/projects/" });
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header container">
      <a href="/" class="site-byline">Sanjay Rajasekharan</a>
      <div class="breadcrumb-slot">
        {crumbs.length > 0 && (
          <nav class="breadcrumb">
            {crumbs.map((c, i) => (
              <>
                {i > 0 && <span class="breadcrumb__sep">/</span>}
                <a href={c.href}>{c.label}</a>
              </>
            ))}
          </nav>
        )}
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        &copy; {new Date().getFullYear()} Sanjay Rajasekharan
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
