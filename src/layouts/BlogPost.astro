---
import Base from "./Base.astro";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={`${title} — Sanjay Rajasekharan`} description={description}>
  <article>
    <div class="post-header">
      <h1>{title}</h1>
      <p class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <span>&nbsp;&middot;&nbsp;{tags.join(", ")}</span>
        )}
      </p>
    </div>
    <slot />
  </article>
</Base>
