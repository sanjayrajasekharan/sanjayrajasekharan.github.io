---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const preview = posts.slice(0, 3);
const hasMore = posts.length > 3;
---

<Base title="Sanjay Rajasekharan">
  <section>
    <h2><a href="/blog/">Blog</a></h2>
    {preview.length === 0 ? (
      <p class="text-muted">Coming soon.</p>
    ) : (
      <ul class="post-list">
        {preview.map((post) => (
          <li class="post-list__item">
            <div class="post-list__meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </div>
            <div class="post-list__title">
              <a href={`/blog/${post.id.replace(/\.mdx?$/, "")}/`}>{post.data.title}</a>
            </div>
            <p class="post-list__excerpt">{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
    {hasMore && (
      <a href="/blog" class="more-link">More &rarr;</a>
    )}
  </section>

  <section class="projects-strip">
    <h2><a href="/projects/">Projects</a></h2>
    <ul class="projects-strip__list">
      <li>
        <a href="https://github.com/sanjayrajasekharan/brim" target="_blank">Possession Impact Model</a>
        <span class="text-muted">&mdash; Bayesian credit assignment for NBA rebounds</span>
      </li>
    </ul>
  </section>
</Base>
