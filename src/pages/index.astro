---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Sanjay Rajasekharan">
  <section>
    <h1>Hi, I'm Sanjay.</h1>
    <p class="subtitle">
      I build Bayesian models, write about basketball analytics,
      and care about doing statistics honestly.
    </p>
  </section>

  <section>
    <h2>Recent writing</h2>
    {posts.length === 0 ? (
      <p class="text-muted">Coming soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-list__item">
            <div class="post-list__meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </div>
            <div class="post-list__title">
              <a href={`/blog/${post.id.replace(/\.mdx?$/, "")}/`}>{post.data.title}</a>
            </div>
            <p class="post-list__excerpt">{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
